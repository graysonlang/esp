{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:8000",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "npm:debug:vscode",
      "postDebugTask": "Kill debug server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/main.mjs"]
    }
  ]
}
